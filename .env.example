# activist-scout configuration
# Copy to `.env` and fill in your credentials. `.env` is gitignored.

# ─── KRX (Korea Exchange) — required for pykrx ───
# Sign up at https://data.krx.co.kr/
KRX_ID=
KRX_PW=

# ─── DART OpenAPI (Korean financial filings) — required ───
# Free API key: https://opendart.fss.or.kr/
DART_API_KEY=

# ─── LLM (choose one or both) ───
# Gemini — used by stages.classify & stages.related_party
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# OpenAI — used by deep_dive.py (single-stock IC reports)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
